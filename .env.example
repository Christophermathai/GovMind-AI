# ─────────────────────────────────────────────────────────────────────────────
# GovMind AI — Example Environment File
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Never commit .env to version control — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Next.js / Frontend) ────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>

# ── Supabase (Python Ingestion Service) ──────────────────────────────────────
# SUPABASE_URL is the same as NEXT_PUBLIC_SUPABASE_URL above.
# SUPABASE_KEY  → use the anon/public key (Project Settings → API → anon public)
# SUPABASE_SERVICE_ROLE_KEY → use the service_role key (keep this secret!)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Python Ingestion Service ──────────────────────────────────────────────────
# URL where the FastAPI ingestion service is running locally.
# Default matches `uvicorn main:app` with default port.
PYTHON_SERVICE_URL=http://127.0.0.1:8000

# ── LLM Provider — Ollama (local, free) ──────────────────────────────────────
# GovMind AI uses Ollama for the Citizen Intelligence chat assistant.
# No API key required — Ollama runs entirely on your machine.
#
# Setup:
#   1. Install Ollama:  https://ollama.com/download
#   2. Pull the model:  ollama pull phi4-mini
#   3. Start Ollama:    ollama serve   (or it starts automatically on most installs)
#
# The default base URL (http://localhost:11434) is used automatically.
# Only uncomment and set OLLAMA_BASE_URL if Ollama is on a non-default host/port.
# OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings — fastembed (local, free) ─────────────────────────────────────
# Embeddings are generated by the Python ingestion service using fastembed
# with the BAAI/bge-small-en-v1.5 model. No configuration needed —
# the model is downloaded automatically on first run.
